@model Inventory.Models.User
@{
    ViewData["Title"] = "Users";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - User Management</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" />
   
</head>
<body style="background: #faf5ff;">

    <div class="dashboard-container">
        <!-- Header - SAME AS DASHBOARD with Purple Gradient -->
        <div class="page-header">
            <div class="header-content">
                <div class="header-title">
                    <i class="fas fa-users"></i>
                    <h1>User Management</h1>
                </div>
                <div class="header-stats">
                    <div class="header-stat-card">
                        <div class="header-stat-label">Total Users</div>
                        <div class="header-stat-value" id="totalUsers">0</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- User Management Grid -->
        <div class="products-grid">
            <!-- Left Column: User Form -->
            <div class="form-card">
                <h3><i class="fas fa-user-plus"></i> <span id="formTitle">Add New User</span></h3>
                <form id="userForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="userId" name="Id" value="0" />
                
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Username <span class="required">*</span></label>
                        <input type="text" id="userName" name="UserName" placeholder="Enter username" class="form-control" />
                        <span class="error" id="userNameError"></span>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email <span class="required">*</span></label>
                        <input type="email" id="email" name="Email" placeholder="user@example.com" class="form-control" />
                        <span class="error" id="emailError"></span>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-lock"></i> Password <span class="required" id="pwdRequired">*</span></label>
                        <input type="password" id="password" name="Password" placeholder="Minimum 4 characters" class="form-control" />
                        <small>Minimum 4 characters</small>
                        <span class="error" id="passwordError"></span>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-user-tag"></i> Role <span class="required">*</span></label>
                        <select id="role" name="Role" class="form-control">
                            <option value="">Select Role</option>
                            <option value="Admin">Admin</option>
                            <option value="Manager">Manager</option>
                            <option value="Staff">Staff</option>
                            <option value="Viewer">Viewer</option>
                        </select>
                        <span class="error" id="roleError"></span>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-primary" id="submitBtn">
                            <i class="fas fa-save"></i> Save User
                        </button>
                        <button type="button" class="btn btn-secondary" id="cancelBtn" style="display:none;">
                            <i class="fas fa-times"></i> Cancel
                        </button>
                    </div>
                </form>
            </div>

            <!-- Right Column: User List -->
            <div class="table-card">
                <h3><i class="fas fa-list"></i> System Users</h3>
            
                <!-- Search Section -->
                <div class="search-section">
                    <div class="search-bar-wrapper">
                        <div class="search-input-group">
                            <input type="text" id="searchInput" placeholder="Search by username, email or role..." class="search-input" />
                            <button class="btn btn-primary" id="searchBtn"><i class="fas fa-search"></i> Search</button>
                            <button class="btn btn-secondary" id="resetSearchBtn"><i class="fas fa-redo"></i> Reset</button>
                        </div>
                        <div class="filter-group">
                            <select id="roleFilter" class="form-control" style="width: auto; min-width: 120px;">
                                <option value="">All Roles</option>
                                <option value="Admin">Admin</option>
                                <option value="Manager">Manager</option>
                                <option value="Staff">Staff</option>
                                <option value="Viewer">Viewer</option>
                            </select>
                            <button class="btn btn-outline" id="filterBtn"><i class="fas fa-filter"></i> Filter</button>
                        </div>
                    </div>
                </div>

                <!-- User Table -->
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="userTableBody">
                            <tr><td colspan="4" style="text-align:center;">Loading users...</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="table-footer">
                        <div class="showing-info">
                            <i class="fas fa-database"></i> Showing: <span id="displayCount">0</span> users
                        </div>
                        <button id="deleteAllBtn" class="delete-all-btn"><i class="fas fa-trash-alt"></i> Delete All</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="toast" class="toast"></div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="~/assests/ajax/js/user/User.js"></script>

    </body>
</html>