@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = $"{ViewBag.UserRole} Dashboard";
}

<div class="dashboard-container">
    <!-- Stats Cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Products</h3>
                <div class="number" id="totalProducts">0</div>
            </div>
            <div class="stat-icon"><i class="fas fa-cubes"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>Low Stock Items</h3>
                <div class="number" id="lowStockCount">0</div>
            </div>
            <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>Total Value</h3>
                <div class="number" id="totalValue">$0</div>
            </div>
            <div class="stat-icon"><i class="fas fa-dollar-sign"></i></div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>Categories</h3>
                <div class="number" id="categoryCount">0</div>
            </div>
            <div class="stat-icon"><i class="fas fa-tags"></i></div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="charts-row">
        <div class="chart-card">
            <h3><i class="fas fa-chart-bar"></i> Stock by Category</h3>
            <canvas id="categoryChart" style="height: 250px;"></canvas>
        </div>
        <div class="chart-card">
            <h3><i class="fas fa-chart-pie"></i> Stock Status Distribution</h3>
            <canvas id="statusChart" style="height: 250px;"></canvas>
        </div>
    </div>

    <!-- Products Table -->
    <div class="table-card">
        <h3><i class="fas fa-list-ul"></i> Recent Inventory Items</h3>
        <div class="table-container">
            <table class="data-table" id="productsTable">
                <thead>
                    <tr>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Stock</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody id="tableBody">
                    <tr><td colspan="6" style="text-align:center;">Loading products...</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Sell Modal -->
<div id="sellModal" class="modal" style="display:none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3><i class="fas fa-shopping-cart"></i> Sell Product</h3>
            <button class="close" id="closeSellModalBtn">&times;</button>
        </div>
        <div class="modal-body">
            <input type="hidden" id="antiForgeryTokenSell" value="" />
            <div class="form-group">
                <label>Product Name</label>
                <input type="text" id="modalProductName" readonly class="form-control" />
                <input type="hidden" id="modalProductId" />
            </div>
            <div class="form-group">
                <label>Available Stock</label>
                <input type="text" id="modalAvailableStock" readonly class="form-control" />
            </div>
            <div class="form-group">
                <label>Quantity to Sell</label>
                <input type="number" id="modalQuantity" class="form-control" min="1" value="1" required />
            </div>
            <div class="form-group">
                <label>Reason</label>
                <select id="modalReason" class="form-control" required>
                    <option value="Sale">Sale</option>
                    <option value="Damaged">Damaged</option>
                    <option value="Expired">Expired</option>
                </select>
            </div>
            <div class="form-group">
                <label>Remarks</label>
                <textarea id="modalRemarks" class="form-control" rows="2"></textarea>
            </div>
            <div class="form-actions">
                <button type="button" id="confirmSellBtn" class="btn btn-primary">Confirm Sale</button>
                <button type="button" class="btn btn-danger" id="cancelSellBtn">Cancel</button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="~/assests/ajax/js/Home/home.js"></script>

