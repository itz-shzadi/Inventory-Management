<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InventoryMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/notification.css" asp-append-version="true" />
    <!-- Add this BEFORE your Notification.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    
</head>
<body>

    <div class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <i class="fas fa-boxes"></i>
                <span>InventoryMS</span>
            </div>
            <div class="version">@ViewBag.UserRole Portal v2.0</div>
        </div>
        
        <!-- MAIN NAVIGATION -->
        <div class="nav-section">
            <div class="nav-title">MAIN NAVIGATION</div>
            <ul class="nav-menu">
                <!-- Dashboard - Everyone -->
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Dashboard" ? "active" : "")"
                           asp-controller="Account" asp-action="Dashboard">
                        <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
                    </a>
                </li>
                
                <!-- User Management - ONLY ADMIN -->
                @if (ViewBag.CanManageUsers == true)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")"
                               asp-controller="User" asp-action="Index">
                            <i class="fas fa-users"></i><span>User Management</span>
                        </a>
                    </li>
                }
                
                <!-- Products - ADMIN and MANAGER only -->
                @if (ViewBag.CanManageProducts == true)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")"
                               asp-controller="Product" asp-action="Index">
                            <i class="fas fa-box"></i><span>Products</span>
                        </a>
                    </li>
                }
                
                <!-- Categories - ADMIN and MANAGER only -->
                @if (ViewBag.CanManageCategories == true)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")"
                               asp-controller="Category" asp-action="Index">
                            <i class="fas fa-tags"></i><span>Categories</span>
                        </a>
                    </li>
                }
                
                <!-- Suppliers - ADMIN and MANAGER only -->
                @if (ViewBag.CanManageSuppliers == true)
                {
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Supplier" ? "active" : "")"
                               asp-controller="Supplier" asp-action="Index">
                            <i class="fas fa-truck"></i><span>Suppliers</span>
                        </a>
                    </li>
                }
            </ul>
        </div>
        
        <div class="nav-divider"></div>
        
        <!-- STOCK MANAGEMENT - EVERYONE -->
        <div class="nav-section">
            <div class="nav-title">STOCK MANAGEMENT</div>
            <ul class="nav-menu">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "StockIn" ? "active" : "")"
                           asp-controller="Stock" asp-action="StockIn">
                        <i class="fas fa-arrow-down"></i><span>Stock In</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "StockOut" ? "active" : "")"
                           asp-controller="Stock" asp-action="StockOut">
                        <i class="fas fa-arrow-up"></i><span>Stock Out</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "CurrentStock" ? "active" : "")"
                           asp-controller="Stock" asp-action="CurrentStock">
                        <i class="fas fa-boxes"></i><span>Current Stock</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "LowStockReport" ? "active" : "")"
                           asp-controller="Stock" asp-action="LowStockReport">
                        <i class="fas fa-exclamation-triangle"></i><span>Low Stock Report</span>
                    </a>
                </li>
            </ul>
        </div>
        
        <div class="nav-divider"></div>
        
        <!-- ANALYTICS - Everyone can view reports -->
        <div class="nav-section">
            <div class="nav-title">ANALYTICS</div>
            <ul class="nav-menu">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Reports" ? "active" : "")"
                           asp-controller="Stock" asp-action="Reports">
                        <i class="fas fa-chart-line"></i><span>Reports</span>
                    </a>
                </li>
            </ul>
        </div>

    </div>

    <div class="main-content">
        <div class="top-navbar">
            <button class="menu-toggle" id="menuToggle">
                <i class="fas fa-bars"></i>
            </button>
            <div class="page-title">
                <i class="fas fa-chart-line"></i> @ViewData["Title"]
            </div>
            
            <div class="user-menu">
                <span class="user-name">
                    <div class="notification-container">
                        <button class="notification-btn" id="notificationBell">
                            <i class="fas fa-bell"></i>
                            <span class="notification-badge" id="notificationBadge">0</span>
                        </button>
    
                        <div class="notification-dropdown" id="notificationDropdown" style="display: none;">
                            <div class="notification-header">
                                <h4>Notifications</h4>
                                <button id="markAllReadBtn" class="btn-mark-read">Mark all as read</button>
                            </div>
                            <div class="notification-list" id="notificationList">
                                <div class="loading">Loading notifications...</div>
                            </div>
                        </div>
                    </div>
                    <i class="fas @(ViewBag.UserRole == "Admin" ? "fa-shield-alt" : ViewBag.UserRole == "Manager" ? "fa-user-tie" : "fa-user")"></i>
                    @ViewBag.UserName
                </span>
                <div class="user-avatar" onclick="logout()">
                    <i class="fas fa-sign-out-alt"></i>
                </div>
            </div>
        </div>
        
        <div class="content-wrapper">
            @RenderBody()
        </div>
        
        <div class="footer">
            © 2026 - Inventory Management System | Logged in as: <strong>@ViewBag.UserRole</strong> |
            @if (ViewBag.UserRole == "Admin")
            {
                <span class="full-access"><i class="fas fa-crown"></i> Full Access</span>
            }
            else if (ViewBag.UserRole == "Manager")
            {
                <span class="limited-access"><i class="fas fa-chart-line"></i> Limited Access (No User Management)</span>
            }
            else
            {
                <span class="stock-access"><i class="fas fa-user-check"></i> Stock Only Access</span>
            }
        </div>
    </div>

    <div id="toast" class="toast"></div>

    <form id="antiForgeryForm" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
   <script src="~/assests/Ajax/js/Notification/Notification.js"></script>
    
    <script>
        function showToast(message, type) {
        var toast = $('#toast');
        toast.removeClass('success error warning info').addClass(type || 'success');
        toast.html(message);
        toast.fadeIn(300);
        setTimeout(function() { toast.fadeOut(300); }, 3000);
        }
        
        function logout() {
        var token = $('input[name="__RequestVerificationToken"]').val();
        if (!token) token = $('#antiForgeryForm input[name="__RequestVerificationToken"]').val();
            
        var formData = new URLSearchParams();
        if (token) formData.append('__RequestVerificationToken', token);
            
        $.ajax({
        url: '/Account/Logout',
        method: 'POST',
        data: formData.toString(),
        contentType: 'application/x-www-form-urlencoded',
        success: function(response) {
        window.location.href = '/Account/Login';
        },
        error: function() {
        window.location.href = '/Account/Login';
        }
        });
        }
        
        $(document).ready(function() {
        $('#menuToggle').on('click', function() {
        $('#sidebar').toggleClass('open');
        });
            
        // Close sidebar when clicking outside on mobile
        $(document).on('click', function(e) {
        if ($(window).width() <= 768) {
        if (!$(e.target).closest('#sidebar').length && !$(e.target).closest('#menuToggle').length) {
        $('#sidebar').removeClass('open');
        }
        }
        });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>